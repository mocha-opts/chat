datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

model ApiKey {
  id       String         @id @default(uuid()) @db.Uuid
  type     EnumApiKeyType @default(default)
  name     String
  key      String
  hash     String
  isActive Boolean        @default(true)
  startAt  DateTime?
  endAt    DateTime?

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  @@unique(fields: [key])
  @@unique(fields: [hash])
  @@index(fields: [isActive, type, createdAt(sort: Desc)])
  @@index(fields: [name])
  @@map("ApiKeys")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  description String?
  type        EnumRoleType @default(user)
  abilities   Json[]

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  users User[] @relation("UserRole")

  @@unique(fields: [name])
  @@index(fields: [type, createdAt(sort: Desc)])
  @@map("Roles")
}

model Country {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  alpha2Code String
  alpha3Code String
  phoneCode  String[]
  continent  String
  timezone   String

  mobileNumbers UserMobileNumber[] @relation("UserMobileNumberCountry")
  users         User[]             @relation("UserCountry")

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  @@unique(fields: [alpha2Code])
  @@unique(fields: [alpha3Code])
  @@index(fields: [continent])
  @@index(fields: [name])
  @@map("Countries")
}

model UserMobileNumber {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  countryId  String    @db.Uuid
  phoneCode  String
  number     String
  isVerified Boolean   @default(false)
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  country       Country        @relation("UserMobileNumberCountry", fields: [countryId], references: [id])
  user          User           @relation("UserMobileNumberUser", fields: [userId], references: [id])
  verifications Verification[] @relation("UserMobileNumberVerification")

  @@unique(fields: [userId, countryId, phoneCode, number])
  @@index(fields: [userId, isVerified])
  @@index(fields: [number, isVerified])
  @@map("UserMobiles")
}

model User {
  id              String             @id @default(uuid()) @db.Uuid
  name            String?
  username        String
  isVerified      Boolean            @default(false)
  verifiedAt      DateTime?
  email           String
  roleId          String             @db.Uuid
  password        String?
  passwordExpired DateTime?
  passwordCreated DateTime?
  passwordAttempt Int?
  signUpAt        DateTime           @default(now())
  signUpFrom      EnumUserSignUpFrom
  signUpWith      EnumUserSignUpWith
  status          EnumUserStatus     @default(active)
  gender          EnumUserGender?
  countryId       String             @db.Uuid
  lastLoginAt     DateTime?
  lastIPAddress   String?
  lastLoginFrom   EnumUserLoginFrom?
  lastLoginWith   EnumUserLoginWith?
  termPolicy      Json
  photo           Json?

  createdAt DateTime  @default(now())
  createdBy String?   @db.Uuid
  updatedAt DateTime  @updatedAt
  updatedBy String?   @db.Uuid
  deletedAt DateTime?
  deletedBy String?   @db.Uuid

  mobileNumbers              UserMobileNumber[]         @relation("UserMobileNumberUser")
  verifications              Verification[]             @relation("UserVerifications")
  passwordHistories          PasswordHistory[]          @relation("UserPasswordHistories")
  activityLogs               ActivityLog[]              @relation("UserActivityLogs")
  role                       Role                       @relation("UserRole", fields: [roleId], references: [id])
  country                    Country                    @relation("UserCountry", fields: [countryId], references: [id])
  sessions                   Session[]                  @relation("UserSessions")
  acceptances                TermPolicyUserAcceptance[] @relation("TermPolicyUserAcceptanceUser")
  forgotPasswords            ForgotPassword[]           @relation("UserForgotPassword")
  twoFactor                  TwoFactor?                 @relation("UserTwoFactor")
  notifications              Notification[]             @relation("UserNotifications")
  notificationSettings       NotificationUserSetting[]  @relation("UserNotificationSettings")
  deviceOwnerships           DeviceOwnership[]          @relation("DeviceOwnershipUser")
  revokedSessions            Session[]                  @relation("SessionRevokedByUser")
  revokedDeviceOwnerships    DeviceOwnership[]          @relation("DeviceOwnershipRevokedByUser")
  legacyId                   BigInt?                    @unique @map("legacy_id")
  avatar                     String?
  signature                  String?
  balance                    UserBalance?               @relation("UserBalanceUser")
  sentFriendApplications     FriendApplication[]        @relation("FriendApplicationSender")
  receivedFriendApplications FriendApplication[]        @relation("FriendApplicationReceiver")
  friends                    Friend[]                   @relation("FriendUser")
  friendOf                   Friend[]                   @relation("FriendTarget")
  conversationMemberships    ConversationMember[]       @relation("ConversationMemberUser")
  messages                   Message[]                  @relation("MessageSender")
  sentRedPackets             RedPacket[]                @relation("RedPacketSender")
  redPacketReceives          RedPacketReceive[]         @relation("RedPacketReceiveReceiver")
  balanceLogs                BalanceLog[]               @relation("BalanceLogUser")
  moments                    Moment[]                   @relation("MomentUser")
  momentLikes                MomentLike[]               @relation("MomentLikeUser")
  momentComments             MomentComment[]            @relation("MomentCommentUser")

  @@unique(fields: [username])
  @@unique(fields: [email])
  @@index(fields: [id, deletedAt])
  @@index(fields: [email, deletedAt])
  @@index(fields: [status, deletedAt, createdAt(sort: Desc)])
  @@index(fields: [roleId, status, deletedAt])
  @@index(fields: [countryId, status, signUpAt(sort: Desc)])
  @@map("Users")
}

model Verification {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @db.Uuid
  mobileNumberId String?              @db.Uuid
  to             String
  type           EnumVerificationType
  token          String
  expiredAt      DateTime
  verifiedAt     DateTime?
  isUsed         Boolean              @default(false)
  reference      String

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid

  user         User              @relation("UserVerifications", fields: [userId], references: [id])
  mobileNumber UserMobileNumber? @relation("UserMobileNumberVerification", fields: [mobileNumberId], references: [id])

  @@unique(fields: [reference])
  @@index(fields: [token, expiredAt, isUsed, type])
  @@index(fields: [userId, type, isUsed])
  @@map("Verifications")
}

model PasswordHistory {
  id        String                  @id @default(uuid()) @db.Uuid
  userId    String                  @db.Uuid
  password  String
  type      EnumPasswordHistoryType
  expiredAt DateTime

  user User @relation("UserPasswordHistories", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid

  @@index(fields: [userId, expiredAt(sort: Desc)])
  @@map("PasswordHistories")
}

model ActivityLog {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @db.Uuid
  action      EnumActivityLogAction
  ipAddress   String?
  userAgent   Json
  description String
  geoLocation Json?
  metadata    Json?

  user User @relation("UserActivityLogs", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid

  @@index(fields: [userId, createdAt(sort: Desc)])
  @@index(fields: [userId, action, createdAt(sort: Desc)])
  @@map("ActivityLogs")
}

model Session {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  deviceOwnershipId String    @db.Uuid
  jti               String
  ipAddress         String?
  userAgent         Json
  geoLocation       Json?
  expiredAt         DateTime
  revokedAt         DateTime?
  isRevoked         Boolean   @default(false)
  revokedById       String?   @db.Uuid

  revokedBy       User?           @relation("SessionRevokedByUser", fields: [revokedById], references: [id])
  user            User            @relation("UserSessions", fields: [userId], references: [id])
  deviceOwnership DeviceOwnership @relation("DeviceOwnershipSessions", fields: [deviceOwnershipId], references: [id])

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  @@unique(fields: [userId, jti])
  @@index(fields: [userId, expiredAt(sort: Desc), isRevoked])
  @@index(fields: [isRevoked, expiredAt(sort: Asc)])
  @@index(fields: [userId, deviceOwnershipId, isRevoked])
  @@index(fields: [deviceOwnershipId])
  @@map("Sessions")
}

model Device {
  id                   String                          @id @default(uuid()) @db.Uuid
  fingerprint          String
  name                 String?
  platform             EnumDevicePlatform
  lastActiveAt         DateTime                        @default(now())
  notificationToken    String?
  notificationProvider EnumDeviceNotificationProvider?

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  ownerships DeviceOwnership[] @relation("DeviceOwnershipDevice")

  @@unique(fields: [fingerprint])
  @@map("Devices")
}

model DeviceOwnership {
  id           String    @id @default(uuid()) @db.Uuid
  deviceId     String    @db.Uuid
  userId       String    @db.Uuid
  revokedAt    DateTime?
  isRevoked    Boolean   @default(false)
  revokedById  String?   @db.Uuid
  lastActiveAt DateTime  @default(now())

  biometricEnabled   Boolean            @default(false)
  biometricToken     String?
  biometricType      EnumBiometricType?
  biometricEnabledAt DateTime?

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  revokedBy User?     @relation("DeviceOwnershipRevokedByUser", fields: [revokedById], references: [id])
  device    Device    @relation("DeviceOwnershipDevice", fields: [deviceId], references: [id])
  user      User      @relation("DeviceOwnershipUser", fields: [userId], references: [id])
  sessions  Session[] @relation("DeviceOwnershipSessions")

  @@index(fields: [deviceId, revokedAt])
  @@index(fields: [userId, isRevoked])
  @@index(fields: [userId, revokedAt])
  @@index(fields: [deviceId, userId, revokedAt])
  @@map("DeviceOwnerships")
}

model TwoFactor {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  secret        String?
  iv            String?
  backupCodes   String[]  @default([])
  enabled       Boolean   @default(false)
  requiredSetup Boolean   @default(false)
  confirmedAt   DateTime?
  lastUsedAt    DateTime?
  attempt       Int       @default(0)

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  user User @relation("UserTwoFactor", fields: [userId], references: [id])

  @@unique(fields: [userId])
  @@map("TwoFactors")
}

model TermPolicy {
  id          String               @id @default(uuid()) @db.Uuid
  type        EnumTermPolicyType
  contents    Json[]
  version     Int                  @default(1)
  status      EnumTermPolicyStatus @default(draft)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  userAcceptances TermPolicyUserAcceptance[] @relation("TermPolicyUserAcceptanceTermPolicy")

  @@unique(fields: [type, version])
  @@index(fields: [type, status, publishedAt(sort: Desc)])
  @@map("TermPolicies")
}

model TermPolicyUserAcceptance {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  termPolicyId String   @db.Uuid
  acceptedAt   DateTime @default(now())

  user       User       @relation("TermPolicyUserAcceptanceUser", fields: [userId], references: [id])
  termPolicy TermPolicy @relation("TermPolicyUserAcceptanceTermPolicy", fields: [termPolicyId], references: [id])

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid

  @@unique(fields: [userId, termPolicyId])
  @@index(fields: [termPolicyId, acceptedAt(sort: Desc)])
  @@map("TermPolicyUserAcceptances")
}

model FeatureFlag {
  id             String  @id @default(uuid()) @db.Uuid
  key            String
  description    String
  isEnable       Boolean @default(true)
  rolloutPercent Int     @default(100)
  metadata       Json?

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  @@unique(fields: [key])
  @@index(fields: [isEnable])
  @@map("FeatureFlags")
}

model ForgotPassword {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  to        String
  token     String
  expiredAt DateTime
  resetAt   DateTime?
  isUsed    Boolean   @default(false)
  reference String

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid

  user User @relation("UserForgotPassword", fields: [userId], references: [id])

  @@unique(fields: [reference])
  @@index(fields: [token, expiredAt, isUsed])
  @@map("ForgotPasswords")
}

model Notification {
  id       String                   @id @default(uuid()) @db.Uuid
  userId   String                   @db.Uuid
  type     EnumNotificationType
  priority EnumNotificationPriority @default(normal)
  title    String
  body     String
  metadata Json?
  isRead   Boolean                  @default(false)
  readAt   DateTime?

  user       User                   @relation("UserNotifications", fields: [userId], references: [id])
  deliveries NotificationDelivery[] @relation("NotificationDeliveries")

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  @@index(fields: [userId, isRead, createdAt(sort: Desc)])
  @@index(fields: [userId, type, createdAt(sort: Desc)])
  @@index(fields: [userId, priority, isRead, createdAt(sort: Desc)])
  @@map("Notifications")
}

model NotificationDelivery {
  id             String                  @id @default(uuid()) @db.Uuid
  notificationId String                  @db.Uuid
  channel        EnumNotificationChannel
  sentAt         DateTime?
  processedAt    DateTime?
  failureTokens  String[]                @default([])

  notification Notification @relation("NotificationDeliveries", fields: [notificationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique(fields: [notificationId, channel])
  @@index(fields: [channel, createdAt(sort: Desc)])
  @@map("NotificationDeliveries")
}

model NotificationUserSetting {
  id       String                  @id @default(uuid()) @db.Uuid
  userId   String                  @db.Uuid
  channel  EnumNotificationChannel
  type     EnumNotificationType
  isActive Boolean                 @default(true)

  user User @relation("UserNotificationSettings", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  createdBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid

  @@unique(fields: [userId, channel, type])
  @@index(fields: [userId, isActive])
  @@map("NotificationUserSettings")
}

model UserBalance {
  userId    String   @id @db.Uuid
  balance   Decimal  @default(1000.00) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserBalanceUser", fields: [userId], references: [id])

  @@map("user_balances")
}

model VerificationCode {
  id        BigInt                      @id @default(autoincrement())
  target    String
  channel   EnumVerificationCodeChannel
  codeHash  String                      @map("code_hash")
  purpose   EnumVerificationCodePurpose
  expiredAt DateTime                    @map("expired_at")
  usedAt    DateTime?                   @map("used_at")
  createdAt DateTime                    @default(now()) @map("created_at")

  @@index(fields: [target, channel, purpose, expiredAt])
  @@index(fields: [target, channel, purpose, usedAt, createdAt(sort: Desc)])
  @@index(fields: [target, channel, usedAt, createdAt(sort: Desc)])
  @@index(fields: [purpose, usedAt])
  @@map("verification_codes")
}

model FriendApplication {
  id         BigInt                      @id @default(autoincrement())
  senderId   String                      @map("sender_id") @db.Uuid
  receiverId String                      @map("receiver_id") @db.Uuid
  message    String?
  status     EnumFriendApplicationStatus @default(unread)
  expiredAt  DateTime?                   @map("expired_at")
  createdAt  DateTime                    @default(now()) @map("created_at")
  updatedAt  DateTime                    @updatedAt @map("updated_at")

  sender   User @relation("FriendApplicationSender", fields: [senderId], references: [id])
  receiver User @relation("FriendApplicationReceiver", fields: [receiverId], references: [id])

  @@index(fields: [senderId, receiverId, status, createdAt(sort: Desc)])
  @@index(fields: [senderId, createdAt(sort: Desc)])
  @@index(fields: [receiverId, status, createdAt(sort: Desc)])
  @@index(fields: [receiverId, createdAt(sort: Desc)])
  @@map("friend_applications")
}

model Friend {
  id        BigInt           @id @default(autoincrement())
  userId    String           @map("user_id") @db.Uuid
  friendId  String           @map("friend_id") @db.Uuid
  status    EnumFriendStatus @default(normal)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user   User @relation("FriendUser", fields: [userId], references: [id])
  friend User @relation("FriendTarget", fields: [friendId], references: [id])

  @@unique(fields: [userId, friendId])
  @@index(fields: [friendId, status])
  @@index(fields: [userId, status, createdAt(sort: Desc)])
  @@map("friends")
}

model Conversation {
  id        BigInt                 @id @default(autoincrement())
  name      String
  type      EnumConversationType
  status    EnumConversationStatus @default(normal)
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  members    ConversationMember[] @relation("ConversationMembers")
  messages   Message[]            @relation("ConversationMessages")
  redPackets RedPacket[]          @relation("ConversationRedPackets")

  @@index(fields: [type, status, createdAt(sort: Desc)])
  @@map("conversations")
}

model ConversationMember {
  id             BigInt                       @id @default(autoincrement())
  conversationId BigInt                       @map("conversation_id")
  userId         String                       @map("user_id") @db.Uuid
  role           EnumConversationMemberRole   @default(member)
  status         EnumConversationMemberStatus @default(normal)
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")

  conversation Conversation @relation("ConversationMembers", fields: [conversationId], references: [id])
  user         User         @relation("ConversationMemberUser", fields: [userId], references: [id])

  @@unique(fields: [conversationId, userId])
  @@index(fields: [userId, status])
  @@index(fields: [conversationId, role, status])
  @@index(fields: [conversationId, status, createdAt(sort: Asc)])
  @@map("conversation_members")
}

model Message {
  id               BigInt               @id @map("message_id")
  senderId         String               @map("sender_id") @db.Uuid
  conversationId   BigInt               @map("conversation_id")
  conversationType EnumConversationType @map("conversation_type")
  type             EnumMessageType
  content          String?
  body             Json
  replyId          BigInt?              @map("reply_id")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  sender       User            @relation("MessageSender", fields: [senderId], references: [id])
  conversation Conversation    @relation("ConversationMessages", fields: [conversationId], references: [id])
  reply        Message?        @relation("MessageReplies", fields: [replyId], references: [id])
  replies      Message[]       @relation("MessageReplies")
  outboxes     MessageOutbox[] @relation("MessageOutboxes")

  @@index(fields: [conversationId, createdAt(sort: Desc)])
  @@index(fields: [senderId, createdAt(sort: Desc)])
  @@index(fields: [conversationType, type, createdAt(sort: Desc)])
  @@map("messages")
}

model MessageOutbox {
  id          BigInt                  @id @default(autoincrement())
  messageId   BigInt                  @map("message_id")
  topic       String
  messageKey  String                  @map("message_key")
  payload     Json
  status      EnumMessageOutboxStatus @default(init)
  retryCount  Int                     @default(0) @map("retry_count")
  nextRetryAt DateTime?               @map("next_retry_at")
  lastError   String?                 @map("last_error")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  message Message @relation("MessageOutboxes", fields: [messageId], references: [id])

  @@unique(fields: [messageId, topic])
  @@index(fields: [status, nextRetryAt])
  @@index(fields: [status, retryCount, nextRetryAt, createdAt(sort: Asc)])
  @@index(fields: [status, updatedAt, createdAt(sort: Asc)])
  @@index(fields: [topic, status, createdAt(sort: Desc)])
  @@map("message_outboxes")
}

model RedPacket {
  id              BigInt              @id @map("red_packet_id")
  senderId        String              @map("sender_id") @db.Uuid
  conversationId  BigInt              @map("conversation_id")
  wrapperText     String              @map("wrapper_text")
  type            EnumRedPacketType
  totalAmount     Decimal             @map("total_amount") @db.Decimal(18, 2)
  totalCount      Int                 @map("total_count")
  remainingAmount Decimal             @map("remaining_amount") @db.Decimal(18, 2)
  remainingCount  Int                 @map("remaining_count")
  status          EnumRedPacketStatus @default(unclaimed)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  expireAt        DateTime            @map("expire_at")

  sender       User               @relation("RedPacketSender", fields: [senderId], references: [id])
  conversation Conversation       @relation("ConversationRedPackets", fields: [conversationId], references: [id])
  receives     RedPacketReceive[] @relation("RedPacketReceives")

  @@index(fields: [senderId, createdAt(sort: Desc)])
  @@index(fields: [conversationId, createdAt(sort: Desc)])
  @@index(fields: [status, expireAt])
  @@map("red_packets")
}

model RedPacketReceive {
  id          BigInt   @id @default(autoincrement()) @map("red_packet_receive_id")
  redPacketId BigInt   @map("red_packet_id")
  receiverId  String   @map("receiver_id") @db.Uuid
  amount      Decimal  @db.Decimal(18, 2)
  receivedAt  DateTime @default(now()) @map("received_at")

  redPacket RedPacket @relation("RedPacketReceives", fields: [redPacketId], references: [id])
  receiver  User      @relation("RedPacketReceiveReceiver", fields: [receiverId], references: [id])

  @@unique(fields: [redPacketId, receiverId])
  @@index(fields: [redPacketId, receivedAt(sort: Asc)])
  @@index(fields: [receiverId, receivedAt(sort: Desc)])
  @@map("red_packet_receives")
}

model BalanceLog {
  id        BigInt             @id @default(autoincrement()) @map("balance_log_id")
  userId    String             @map("user_id") @db.Uuid
  amount    Decimal            @db.Decimal(18, 2)
  type      EnumBalanceLogType
  relatedId BigInt?            @map("related_id")
  createdAt DateTime           @default(now()) @map("created_at")

  user User @relation("BalanceLogUser", fields: [userId], references: [id])

  @@index(fields: [userId, createdAt(sort: Desc)])
  @@index(fields: [type, relatedId])
  @@map("balance_logs")
}

model Moment {
  id        BigInt    @id @map("moment_id")
  userId    String    @map("user_id") @db.Uuid
  text      String?   @db.Text
  mediaUrls Json      @map("media_urls")
  createdAt DateTime  @default(now()) @map("create_time")
  updatedAt DateTime  @updatedAt @map("update_time")
  deletedAt DateTime? @map("delete_time")

  user     User            @relation("MomentUser", fields: [userId], references: [id])
  likes    MomentLike[]    @relation("MomentLikes")
  comments MomentComment[] @relation("MomentComments")

  @@index(fields: [userId, deletedAt, createdAt(sort: Desc)])
  @@index(fields: [userId, updatedAt(sort: Asc), createdAt(sort: Desc)])
  @@index(fields: [createdAt(sort: Desc)])
  @@map("moments")
}

model MomentLike {
  id        BigInt   @id @default(autoincrement()) @map("like_id")
  momentId  BigInt   @map("moment_id")
  userId    String   @map("user_id") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_delete")
  createdAt DateTime @default(now()) @map("create_time")
  updatedAt DateTime @updatedAt @map("update_time")

  moment Moment @relation("MomentLikes", fields: [momentId], references: [id])
  user   User   @relation("MomentLikeUser", fields: [userId], references: [id])

  @@unique(fields: [momentId, userId])
  @@index(fields: [momentId, isDeleted])
  @@index(fields: [userId, isDeleted, createdAt(sort: Desc)])
  @@index(fields: [userId, updatedAt(sort: Asc)])
  @@map("moment_likes")
}

model MomentComment {
  id              BigInt   @id @default(autoincrement()) @map("comment_id")
  momentId        BigInt   @map("moment_id")
  userId          String   @map("user_id") @db.Uuid
  parentCommentId BigInt?  @map("parent_comment_id")
  content         String   @map("comment") @db.Text
  isDeleted       Boolean  @default(false) @map("is_delete")
  createdAt       DateTime @default(now()) @map("create_time")
  updatedAt       DateTime @updatedAt @map("update_time")

  moment   Moment          @relation("MomentComments", fields: [momentId], references: [id])
  user     User            @relation("MomentCommentUser", fields: [userId], references: [id])
  parent   MomentComment?  @relation("MomentCommentReplies", fields: [parentCommentId], references: [id])
  children MomentComment[] @relation("MomentCommentReplies")

  @@index(fields: [momentId, isDeleted, createdAt(sort: Desc)])
  @@index(fields: [momentId, parentCommentId, isDeleted])
  @@index(fields: [userId, isDeleted, createdAt(sort: Desc)])
  @@index(fields: [userId, updatedAt(sort: Asc)])
  @@index(fields: [parentCommentId])
  @@map("moment_comments")
}

