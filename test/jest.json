{
    "testTimeout": 5000,
    "rootDir": "../",
    "modulePaths": ["."],
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/test/**/*.spec.ts"],
    "transformIgnorePatterns": ["<rootDir>/generated/", "/node_modules/"],
    "clearMocks": true,
    "collectCoverage": false,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
        "<rootDir>/src/{modules,common}/**/services/**/*.service.ts",
        "<rootDir>/src/{modules,common}/**/pipes/**/*.pipe.ts",
        "<rootDir>/src/{modules,common}/**/guards/**/*.guard.ts",
        "<rootDir>/src/{modules,common}/**/guards/**/*.strategy.ts",
        "<rootDir>/src/{modules,common}/**/interceptors/**/*.interceptor.ts",
        "<rootDir>/src/{modules,common,app}/**/dtos/**/*.dto.ts",
        "<rootDir>/src/{modules,common}/**/decorators/**/*.decorator.ts",
        "<rootDir>/src/{modules,common}/**/exceptions/**/*.exception.ts",
        "<rootDir>/src/{modules,common,app}/**/filters/**/*.filter.ts",
        "<rootDir>/src/{modules,common,app}/**/middlewares/**/*.middleware.ts",
        "<rootDir>/src/{modules,common}/**/indicators/**/*.indicator.ts",
        "<rootDir>/src/{modules,common}/**/factories/**/*.factory.ts"
    ],
    "coverageThreshold": {
        "global": {
            "branches": 100,
            "functions": 100,
            "lines": 100,
            "statements": 100
        }
    },
    "coverageReporters": ["html", "lcov", "json-summary"],
    "moduleFileExtensions": ["js", "ts", "json"],
    "moduleNameMapper": {
        "^@app/(.*)$": "<rootDir>/src/app/$1",
        "^@common/(.*)$": "<rootDir>/src/common/$1",
        "^@configs/(.*)$": "<rootDir>/src/configs/$1",
        "^@config$": "<rootDir>/src/configs/index.ts",
        "^@modules/(.*)$": "<rootDir>/src/modules/$1",
        "^@queues/(.*)$": "<rootDir>/src/queues/$1",
        "^@routes/(.*)$": "<rootDir>/src/router/routes/$1",
        "^@router$": "<rootDir>/src/router/router.module.ts",
        "^@migration/(.*)$": "<rootDir>/src/migration/$1",
        "^@test/(.*)$": "<rootDir>/test/$1",
        "^@generated/(.*)$": "<rootDir>/generated/$1",
        "^@prisma/client$": "<rootDir>/generated/prisma-client",
        "^@package$": "<rootDir>/package.json"
    },
    "coverageProvider": "v8",
    "transform": {
        "^.+\\.(t|j)sx?$": [
            "@swc/jest",
            {
                "swcrc": false,
                "sourceMaps": true,
                "module": {
                    "type": "commonjs"
                },
                "jsc": {
                    "target": "esnext",
                    "parser": {
                        "syntax": "typescript",
                        "decorators": true,
                        "dynamicImport": true
                    },
                    "transform": {
                        "legacyDecorator": true,
                        "decoratorMetadata": true
                    }
                }
            }
        ]
    },
    "modulePathIgnorePatterns": ["<rootDir>/dist"]
}
